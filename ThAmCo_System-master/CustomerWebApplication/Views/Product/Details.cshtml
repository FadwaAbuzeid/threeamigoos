@model Customer.Web.ViewModels.ProductViewModel

    <h1>@Html.DisplayFor(model => model.Name)</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class="col-sm-10">
            <a asp-action="ByBrand" asp-route-BrandId="@Html.DisplayFor(model => model.CategoryId)">@Html.DisplayFor(model => model.Category)</a>
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Brand)
        </dt>
        <dd class="col-sm-10">
            <a asp-action="ByBrand" asp-route-BrandId="@Html.DisplayFor(model => model.BrandId)">@Html.DisplayFor(model => model.Brand)</a>
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Quantity)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Quantity)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description) <br>
        </dd>
    </dl>
</div>
<div>
    <hr />
    <a asp-controller="Review" asp-action="Index" asp-route-ProductId="@Model.ProductId" asp-route-ProductName="@Model.Name">Reviews</a>
</div>

